# DeepSeek API key (required unless DRY_RUN=true)
API_KEY=your_deepseek_api_key_here

# LLM sampling temperature
TEMPERATURE=2.0

# true = run the pipeline without any API calls (mocked responses)
DRY_RUN=false

# ---------------------------------------------------------------------------
# System prompts.
# These define the agents' instructions for each phase of a round and are
# read via os.environ[...]. They are required — the simulation will raise
# KeyError on startup if any of these are missing.
#
# The current prompt set used by the author is not yet published in the
# repo. Contact seryakov.na61@gmail.com for the working set, or write
# your own based on the round structure described in the README.
# ---------------------------------------------------------------------------

INTRODUCTORY_PROMPT=
ROUND_START_PROMPT=
TASK_INTRODUCTION_PROMPT=
COLLECT_OPENING_ACTIONS_PROMPT=
SHARING_ACTIONS_PROMPT=
MEMORY_REQUEST_PROMPT=
GENERAL_FEEDBACK_REQUEST_PROMPT=
